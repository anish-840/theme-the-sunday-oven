<div class="custom-product-details-block">
  {% if product != blank %}
    <h1 class="cpd-title">{{ product.title }}</h1>
    
    <div class="cpd-price-wrapper">
      {% if product.compare_at_price > product.price %}
        <span class="cpd-price-sale">{{ product.price | money }}</span>
        <span class="cpd-price-compare"><s>{{ product.compare_at_price | money }}</s></span>
      {% else %}
        <span class="cpd-price">{{ product.price | money }}</span>
      {% endif %}
    </div>

    <div class="cpd-description">
      {{ product.description }}
    </div>

    {%- form 'product', product, id: 'product-form-custom', class: 'cpd-form' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      
      {% unless product.has_only_default_variant %}
        <div class="cpd-variant-picker">
          <label for="Option-{{ product.id }}" class="cpd-label">Size</label>
          <div class="cpd-select-wrapper">
            <select id="Option-{{ product.id }}" class="cpd-select" name="id" onchange="this.form.querySelector('[name=id]').value = this.value">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %} {% unless variant.available %}disabled="disabled"{% endunless %}>
                  {{ variant.title }}
                </option>
              {% endfor %}
            </select>
          </div>
        </div>
      {% endunless %}

      <div class="cpd-inventory">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 6L9 17l-5-5"/></svg>
        {% if product.selected_or_first_available_variant.inventory_quantity > 0 %}
          There are {{ product.selected_or_first_available_variant.inventory_quantity }} products left
        {% else %}
          Out of stock
        {% endif %}
      </div>

      <div class="cpd-price-large">
        {{ product.price | money }}
      </div>

      <div class="cpd-actions">
        
        <div class="cpd-quantity-selector">
          <button type="button" class="cpd-qty-btn minus" aria-label="Decrease quantity" onclick="this.parentNode.querySelector('input').stepDown()">−</button>
          <input type="number" name="quantity" value="1" min="1" class="cpd-qty-input" aria-label="Quantity">
          <button type="button" class="cpd-qty-btn plus" aria-label="Increase quantity" onclick="this.parentNode.querySelector('input').stepUp()">+</button>
        </div>

        <button type="submit" name="add" class="cpd-btn-add" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
          {% if product.selected_or_first_available_variant.available %}
            Add to cart
          {% else %}
            Sold out
          {% endif %}
        </button>

        <div class="cpd-dynamic-checkout">
          {{ form | payment_button }}
        </div>
        
      </div>
    {%- endform -%}
  {% else %}
    <p>Please view this block on a product page.</p>
  {% endif %}
</div>

<style>
  /* Base Container Styles */
  .custom-product-details-block {
    font-family: inherit;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 24px; /* More elegant spacing */
    width: 100%;
    max-width: 520px; /* Prevents text from stretching too wide */
    text-align: left;
    transition: transform 0.3s ease;
  }

  /* DESKTOP ONLY: Move 60px to the left */
  @media screen and (min-width: 990px) {
    .custom-product-details-block {
      transform: translateX(-60px);
    }
  }

  /* Typography */
  .cpd-title { 
    font-size: clamp(2.5rem, 4vw, 3.8rem); 
    font-weight: 500; 
    letter-spacing: -0.02em; /* Tighter heading for a premium look */
    margin: 0; 
    line-height: 1.05; 
    color: inherit; 
  }
  
  .cpd-price-wrapper { 
    font-size: 1.5rem; 
    font-weight: 600; 
    opacity: 0.9;
  }
  
  .cpd-price-compare { 
    opacity: 0.5; 
    font-size: 1.2rem; 
    margin-left: 10px; 
  }
  
  .cpd-description { 
    font-size: 1.05rem; 
    line-height: 1.6; /* Taller line height for better reading */
    margin-top: 5px; 
    opacity: 0.85; 
  }

  /* Dropdown Settings */
  .cpd-variant-picker { margin-top: 10px; }
  
  .cpd-label { 
    display: block; 
    font-weight: 600; 
    margin-bottom: 12px; 
    font-size: 0.85rem; 
    text-transform: uppercase; 
    letter-spacing: 1px;
    opacity: 0.9;
  }
  
  .cpd-select-wrapper { position: relative; }
  
  .cpd-select { 
    width: 100%; 
    appearance: none; 
    background: transparent; 
    border: 1px solid rgba(0,0,0,0.3); 
    border-radius: 8px; 
    padding: 16px 20px; 
    font-size: 1.05rem; 
    cursor: pointer; 
    color: inherit; 
    transition: border-color 0.3s;
  }
  
  .cpd-select:focus {
    outline: none;
    border-color: rgba(0,0,0,0.8);
  }
  
  .cpd-select-wrapper::after { 
    content: "▼"; 
    position: absolute; 
    right: 20px; 
    top: 50%; 
    transform: translateY(-50%); 
    pointer-events: none; 
    font-size: 0.7rem; 
    opacity: 0.7; 
  }

  /* Inventory Tag */
  .cpd-inventory { 
    display: inline-flex; 
    align-items: center; 
    gap: 8px; 
    font-size: 0.9rem; 
    margin-top: 5px; 
    padding: 8px 14px; 
    border: 1px solid rgba(0,0,0,0.15); 
    border-radius: 6px; 
    width: fit-content; 
    color: inherit; 
    opacity: 0.9;
  } 

  /* Bottom Price */
  .cpd-price-large { 
    font-size: clamp(3rem, 5vw, 4.2rem); 
    font-weight: 500; 
    letter-spacing: -0.02em;
    margin-top: 15px; 
    margin-bottom: 5px; 
    line-height: 1; 
  }

  /* Actions Line */
  .cpd-actions { 
    display: flex; 
    gap: 12px; 
    margin-top: 5px; 
    align-items: center; 
    flex-wrap: nowrap; 
  }

  .cpd-quantity-selector { 
    display: flex; 
    align-items: center; 
    border: 1px solid rgba(0,0,0,0.3); 
    border-radius: 40px; 
    padding: 0 5px; 
    height: 55px; 
    flex: 0 0 100px; 
  }
  
  .cpd-qty-btn { 
    background: transparent; 
    border: none; 
    font-size: 1.4rem; 
    width: 30px; 
    height: 100%; 
    cursor: pointer; 
    color: inherit; 
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  
  .cpd-qty-btn:hover { opacity: 1; }
  
  .cpd-qty-input { 
    width: 30px; 
    text-align: center; 
    border: none; 
    background: transparent; 
    font-size: 1.1rem; 
    font-weight: 500; 
    color: inherit; 
    -moz-appearance: textfield; 
  }
  
  .cpd-qty-input::-webkit-outer-spin-button, 
  .cpd-qty-input::-webkit-inner-spin-button { 
    -webkit-appearance: none; 
    margin: 0; 
  }

  /* Buttons */
  .cpd-btn-add { 
    flex: 1 1 auto; 
    background-color: #000; 
    color: #c4906a; /* Matches the tan text inside the black button */
    border: none; 
    border-radius: 40px; 
    font-size: 1.05rem; 
    font-weight: 600; 
    letter-spacing: 0.5px;
    cursor: pointer; 
    height: 55px; 
    transition: all 0.3s ease; 
    min-width: 120px; 
    padding: 0 15px; 
    white-space: nowrap; 
  }
  
  .cpd-btn-add:hover { 
    background-color: #222; 
    transform: translateY(-2px);
  }
  
  .cpd-btn-add:disabled { 
    opacity: 0.5; 
    cursor: not-allowed; 
    transform: none;
  }

  .cpd-dynamic-checkout { 
    flex: 1 1 auto; 
    min-width: 120px; 
  }
  
  .shopify-payment-button { width: 100% !important; margin: 0 !important; }
  
  .shopify-payment-button__button { 
    height: 55px !important; 
    border-radius: 40px !important; 
    border: 1px solid rgba(0,0,0,0.3) !important; 
    background: transparent !important; 
    color: inherit !important; 
    font-size: 1.05rem !important; 
    font-weight: 600 !important; 
    letter-spacing: 0.5px !important;
    padding: 0 15px !important; 
    white-space: nowrap !important; 
    transition: all 0.3s ease !important;
  }
  
  .shopify-payment-button__button:hover { 
    background: rgba(0,0,0,0.05) !important; 
    border-color: rgba(0,0,0,0.8) !important;
  }

  /* Mobile Wrapping */
  @media screen and (max-width: 768px) {
    .cpd-actions { flex-wrap: wrap; }
    .cpd-quantity-selector { flex: 0 0 100px; }
    .cpd-btn-add { flex: 1 1 calc(100% - 112px); }
    .cpd-dynamic-checkout { flex: 0 0 100%; margin-top: 5px; }
  }
</style>