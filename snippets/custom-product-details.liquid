<div class="custom-product-details-block">
  {% if product != blank %}
    <h1 class="cpd-title">{{ product.title }}</h1>
    
    <div class="cpd-price-wrapper">
      {% if product.compare_at_price > product.price %}
        <span class="cpd-price-sale">{{ product.price | money }}</span>
        <span class="cpd-price-compare"><s>{{ product.compare_at_price | money }}</s></span>
      {% else %}
        <span class="cpd-price">{{ product.price | money }}</span>
      {% endif %}
    </div>

    <div class="cpd-description">
      {{ product.description }}
    </div>

    {%- form 'product', product, id: 'product-form-custom', class: 'cpd-form' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      
      {% unless product.has_only_default_variant %}
        <div class="cpd-variant-picker">
          <label class="cpd-label">{{ product.options[0] }}</label>
          
          <div class="cpd-pill-group">
            {% for variant in product.variants %}
              <input 
                type="radio" 
                id="Variant-{{ variant.id }}" 
                name="variant_selection" 
                value="{{ variant.id }}"
                class="cpd-variant-radio"
                {% if variant == product.selected_or_first_available_variant %}checked{% endif %}
                {% unless variant.available %}disabled{% endunless %}
                onchange="this.form.querySelector('input[name=id]').value = this.value"
              >
              <label for="Variant-{{ variant.id }}" class="cpd-variant-pill">
                {{ variant.title }}
              </label>
            {% endfor %}
          </div>
        </div>
      {% endunless %}

      <div class="cpd-inventory">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
        {% if product.selected_or_first_available_variant.inventory_quantity > 0 %}
          There are {{ product.selected_or_first_available_variant.inventory_quantity }} products left
        {% else %}
          Out of stock
        {% endif %}
      </div>

      <div class="cpd-price-large">
        {{ product.price | money }}
      </div>

      <div class="cpd-actions">
        
        <div class="cpd-quantity-selector">
          <button type="button" class="cpd-qty-btn minus" onclick="this.parentNode.querySelector('input').stepDown()">−</button>
          <input type="number" name="quantity" value="1" min="1" class="cpd-qty-input">
          <button type="button" class="cpd-qty-btn plus" onclick="this.parentNode.querySelector('input').stepUp()">+</button>
        </div>

        <button type="submit" name="add" class="cpd-btn-add" {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
          {% if product.selected_or_first_available_variant.available %}
            Add to cart
          {% else %}
            Sold out
          {% endif %}
        </button>

        <div class="cpd-dynamic-checkout">
          {{ form | payment_button }}
        </div>
        
      </div>
    {%- endform -%}
  {% else %}
    <p>Please view this block on a product page.</p>
  {% endif %}
</div>

<style>
  .custom-product-details-block {
    font-family: inherit;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    text-align: left;
  }
  .cpd-title { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 600; margin: 0; line-height: 1.1; color: inherit; }
  .cpd-price-wrapper { font-size: 1.8rem; font-weight: 600; }
  .cpd-price-compare { opacity: 0.5; font-size: 1.2rem; margin-left: 10px; }
  .cpd-description { font-size: 1.05rem; line-height: 1.5; margin-top: 5px; opacity: 0.9; }
  
  /* --- NEW RECTANGLE PILL STYLES --- */
  .cpd-variant-picker { margin-top: 15px; }
  .cpd-label { display: block; font-weight: 600; margin-bottom: 12px; font-size: 1.1rem; }
  
  .cpd-pill-group {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .cpd-variant-radio {
    display: none; /* Hides the default circle radio button */
  }

  .cpd-variant-pill {
    flex: 1; /* Makes them equal width side-by-side */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 10px;
    border: 1px solid rgba(0,0,0,0.4);
    border-radius: 4px; /* Slight rounding, change to 0 for sharp corners */
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    text-align: center;
    background: transparent;
    color: inherit;
  }

  /* When the pill is selected */
  .cpd-variant-radio:checked + .cpd-variant-pill {
    background-color: #000;
    color: #c4906a; /* The theme's accent color */
    border-color: #000;
  }

  /* When the pill is out of stock */
  .cpd-variant-radio:disabled + .cpd-variant-pill {
    opacity: 0.4;
    text-decoration: line-through;
    cursor: not-allowed;
    background-color: rgba(0,0,0,0.05);
  }
  /* --------------------------------- */
  
  .cpd-inventory { display: inline-flex; align-items: center; gap: 6px; font-size: 0.85rem; margin-top: 10px; padding: 6px 12px; border: 1px solid rgba(0,0,0,0.1); border-radius: 6px; width: fit-content; color: inherit; }
  .cpd-price-large { font-size: clamp(3rem, 6vw, 4.5rem); font-weight: 600; margin-top: 20px; margin-bottom: 10px; line-height: 1; }
  
  .cpd-actions { 
    display: flex; 
    gap: 12px; 
    margin-top: 10px; 
    align-items: center; 
    flex-wrap: nowrap; 
  }
  
  .cpd-quantity-selector { display: flex; align-items: center; border: 1px solid rgba(0,0,0,0.4); border-radius: 40px; padding: 0 5px; height: 55px; flex: 0 0 100px; }
  .cpd-qty-btn { background: transparent; border: none; font-size: 1.4rem; width: 30px; height: 100%; cursor: pointer; color: inherit; }
  .cpd-qty-input { width: 30px; text-align: center; border: none; background: transparent; font-size: 1.1rem; font-weight: 500; color: inherit; -moz-appearance: textfield; }
  .cpd-qty-input::-webkit-outer-spin-button, .cpd-qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  
  .cpd-btn-add { flex: 1 1 auto; background-color: #000; color: #c4906a; border: none; border-radius: 40px; font-size: 1.1rem; font-weight: 600; cursor: pointer; height: 55px; transition: opacity 0.3s; min-width: 120px; padding: 0 15px; white-space: nowrap; }
  .cpd-btn-add:hover { opacity: 0.8; }
  .cpd-btn-add:disabled { opacity: 0.5; cursor: not-allowed; }
  
  .cpd-dynamic-checkout { flex: 1 1 auto; min-width: 120px; }
  .shopify-payment-button { width: 100% !important; margin: 0 !important; }
  .shopify-payment-button__button { height: 55px !important; border-radius: 40px !important; border: 1px solid rgba(0,0,0,0.4) !important; background: transparent !important; color: inherit !important; font-size: 1.1rem !important; font-weight: 600 !important; padding: 0 15px !important; white-space: nowrap !important; }
  .shopify-payment-button__button:hover { background: rgba(0,0,0,0.05) !important; }

  @media screen and (max-width: 768px) {
    .cpd-actions { flex-wrap: wrap; }
    .cpd-quantity-selector { flex: 0 0 100px; }
    .cpd-btn-add { flex: 1 1 calc(100% - 112px); } 
    .cpd-dynamic-checkout { flex: 0 0 100%; margin-top: 5px; } 
  }
</style>