{% comment %}
  ╔══════════════════════════════════════════════════════════════╗
  ║  THE SUNDAY OVEN — Story, Guide & Reviews                    ║
  ║  File: sections/our-story.liquid                             ║
  ╚══════════════════════════════════════════════════════════════╝
{% endcomment %}

{{ 'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&display=swap' | stylesheet_tag }}

<style>
  :root {
    --so-caramel:       #C07D4A;
    --so-caramel-light: #D4935E;
    --so-caramel-bg:    #C8824C;
    --so-cream:         #F5EDD9;
    --so-cream-dark:    #EDD9B8;
    --so-dark:          #1A1008;
    --so-dark-mid:      #2D1E0F;
    --so-text:          #3A2510;
    --so-muted:         #7A5235;
    --so-white:         #FDFAF4;
  }

  .so-wrap *, .so-wrap *::before, .so-wrap *::after { box-sizing: border-box; }
  .so-wrap { 
    overflow-x: hidden; 
    font-family: 'DM Sans', sans-serif; 
    color: var(--so-text); 
    background: var(--so-cream);
  }

  /* ── SHARED TYPOGRAPHY ── */
  .so-section { padding: 6rem 2rem; max-width: 1200px; margin: 0 auto; text-align: center; }
  .so-heading {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: var(--so-dark);
    line-height: 1.1;
    margin-bottom: 2rem;
  }
  .so-heading em { font-style: italic; color: var(--so-caramel); }
  
  /* ── OUR STORY ── */
  .so-story-text {
    max-width: 800px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.85;
    color: var(--so-muted);
  }
  .so-story-text p { margin-bottom: 1.5rem; }

  /* ── GUIDE TO BAKE ── */
  .so-guide-section { background: var(--so-white); border-radius: 40px; padding: 6rem 2rem; margin: 2rem auto; max-width: 1200px;}
  .so-guide-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 4rem;
  }
  .so-guide-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }
  .so-guide-step:not(:last-child)::after {
    content: '→';
    position: absolute;
    top: 25%;
    right: -2rem;
    font-size: 2rem;
    color: var(--so-caramel-light);
    opacity: 0.5;
  }
  .so-step-icon {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 100px;
    background: var(--so-cream);
    border-radius: 50%;
    border: 1px solid rgba(192,125,74,0.2);
    transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.4s;
  }
  .so-guide-step:hover .so-step-icon {
    transform: translateY(-10px) scale(1.05);
    box-shadow: 0 15px 30px rgba(192,125,74,0.15);
  }
  .so-step-text {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: var(--so-dark);
    font-style: italic;
  }
  .so-guide-closing {
    margin-top: 4rem;
    font-size: 1.1rem;
    color: var(--so-caramel);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  /* ── REVIEWS ── */
  .so-reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 4rem;
  }
  .so-review-card {
    background: var(--so-white);
    padding: 3rem 2rem;
    border-radius: 20px;
    border: 1px solid rgba(192,125,74,0.15);
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .so-review-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 35px rgba(192,125,74,0.1);
  }
  .so-review-card::before {
    content: '“';
    position: absolute;
    top: 1rem;
    left: 1.5rem;
    font-family: 'Playfair Display', serif;
    font-size: 5rem;
    color: rgba(192,125,74,0.15);
    line-height: 1;
  }
  .so-review-quote {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-style: italic;
    color: var(--so-dark);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }
  .so-review-author {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--so-caramel);
    font-weight: 500;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .so-guide-grid { grid-template-columns: 1fr; gap: 2rem; }
    .so-guide-step:not(:last-child)::after {
      content: '↓';
      top: auto;
      bottom: -2rem;
      right: 50%;
      transform: translateX(50%);
    }
    .so-section { padding: 4rem 1.5rem; }
    .so-guide-section { padding: 4rem 1.5rem; margin: 1rem; border-radius: 24px; }
  }
</style>

<div class="so-wrap" id="so-section-{{ section.id }}">

  {%- comment -%} ══ OUR STORY ══ {%- endcomment -%}
  <section class="so-section">
    <h2 class="so-heading">{{ section.settings.story_title }}</h2>
    <div class="so-story-text">
      {{ section.settings.story_text }}
    </div>
  </section>

  {%- comment -%} ══ GUIDE TO BAKE ══ {%- endcomment -%}
  <section class="so-section so-guide-section">
    <h2 class="so-heading">{{ section.settings.guide_title }}</h2>
    
    <div class="so-guide-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'guide_step' -%}
          <div class="so-guide-step" {{ block.shopify_attributes }}>
            <span class="so-step-icon">
              {%- if block.settings.icon_image != blank -%}
                {{ block.settings.icon_image | image_url: width: 80 | image_tag: loading: 'lazy', style: 'width: 45px; height: 45px; object-fit: contain;' }}
              {%- else -%}
                {{ block.settings.icon }}
              {%- endif -%}
            </span>
            <p class="so-step-text">{{ block.settings.text }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.guide_closing != blank -%}
      <p class="so-guide-closing">{{ section.settings.guide_closing }}</p>
    {%- endif -%}
  </section>

  {%- comment -%} ══ REVIEWS ══ {%- endcomment -%}
  <section class="so-section">
    <h2 class="so-heading">{{ section.settings.reviews_title }}</h2>
    <div class="so-reviews-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <div class="so-review-card" {{ block.shopify_attributes }}>
            <p class="so-review-quote">{{ block.settings.quote }}</p>
            <p class="so-review-author">— {{ block.settings.author }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>

</div>

<script>
(function() {
  // Simple Scroll Reveal
  var revealEls = document.querySelectorAll('.so-guide-step, .so-review-card');
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          entry.target.style.opacity   = '1';
          entry.target.style.transform = 'translateY(0)';
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    
    revealEls.forEach(function(el) {
      el.style.opacity   = '0';
      el.style.transform = 'translateY(20px)';
      io.observe(el);
    });
  }
})();
</script>

{% schema %}
{
  "name": "Story & Guide",
  "tag": "section",
  "class": "story-guide-section",
  "settings": [
    {
      "type": "header",
      "content": "Our Story"
    },
    {
      "type": "text",
      "id": "story_title",
      "label": "Story Title",
      "default": "Where It All Began"
    },
    {
      "type": "richtext",
      "id": "story_text",
      "label": "Story Text",
      "default": "<p>The Sunday Oven was inspired by the simple joy of baking at home — slow moments, warm kitchens, and the smell of something sweet in the oven.</p><p>We wanted to make that feeling accessible anytime, without the effort of starting from scratch. So you can bake when you want, as often as you want — and still feel like you made it yourself.</p>"
    },
    {
      "type": "header",
      "content": "Guide to Bake"
    },
    {
      "type": "text",
      "id": "guide_title",
      "label": "Guide Title",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "guide_closing",
      "label": "Guide Closing Line",
      "default": "Freshly baked, straight from your oven — whenever you want."
    },
    {
      "type": "header",
      "content": "Reviews"
    },
    {
      "type": "text",
      "id": "reviews_title",
      "label": "Reviews Title",
      "default": "Baked & Loved"
    }
  ],
  "blocks": [
    {
      "type": "guide_step",
      "name": "Bake Step",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon Emoji",
          "default": "🔥"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon Image (Overrides Emoji)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Step Text",
          "default": "Pre heat"
        }
      ]
    },
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review Quote",
          "default": "It’s not just cookies — it’s the whole baking experience at home."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Reviewer Name",
          "default": "Happy Baker"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story & Guide",
      "blocks": [
        {
          "type": "guide_step",
          "settings": { "icon": "🔥", "text": "Pre heat" }
        },
        {
          "type": "guide_step",
          "settings": { "icon": "🍪", "text": "Place on a tray" }
        },
        {
          "type": "guide_step",
          "settings": { "icon": "✨", "text": "Bake & enjoy the aroma" }
        },
        {
          "type": "review",
          "settings": { "quote": "It’s not just cookies — it’s the whole baking experience at home.", "author": "Sneha R." }
        },
        {
          "type": "review",
          "settings": { "quote": "My kitchen smells amazing every time I bake these!", "author": "Rahul M." }
        },
        {
          "type": "review",
          "settings": { "quote": "So easy, yet feels like I baked from scratch.", "author": "Priya K." }
        }
      ]
    }
  ]
}
{% endschema %}