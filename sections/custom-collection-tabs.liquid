<div class="custom-collection-tabs-section" id="CollectionTabs-{{ section.id }}" style="
  --bg-color: {{ section.settings.bg_color }};
  --card-bg-color: {{ section.settings.card_bg_color }};
  --text-color: {{ section.settings.text_color }};
  --tab-active-bg: {{ section.settings.tab_active_bg }};
  --tab-active-text: {{ section.settings.tab_active_text }};
  --badge-bg: {{ section.settings.badge_bg }};
  --badge-text: {{ section.settings.badge_text }};
">
  
  <div class="cct-header">
    {% if section.settings.title != blank %}
      <h2 class="cct-title">{{ section.settings.title }}</h2>
    {% endif %}

    {% if section.settings.collection_2 != blank %}
      <div class="cct-tabs-nav">
        <button class="cct-tab-btn active" data-target="tab-1-{{ section.id }}">
          {{ section.settings.tab_1_label | default: section.settings.collection_1.title | default: 'Collection 1' }}
        </button>
        <button class="cct-tab-btn" data-target="tab-2-{{ section.id }}">
          {{ section.settings.tab_2_label | default: section.settings.collection_2.title | default: 'Collection 2' }}
        </button>
      </div>
    {% endif %}
  </div>

  <div class="cct-tabs-container">
    
    <div class="cct-tab-pane active" id="tab-1-{{ section.id }}">
      <div class="cct-carousel-wrapper">
        <div class="cct-carousel-track">
          {% if section.settings.collection_1 != blank %}
            {% for product in section.settings.collection_1.products limit: section.settings.product_limit %}
              
              <div class="cct-product-card">
                <a href="{{ product.url }}" class="cct-card-link-wrapper">
                  
                  <div class="cct-badges">
                    {% if product.compare_at_price > product.price %}
                      {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                      <span class="cct-badge">-{{ discount }}%</span>
                    {% endif %}
                    {% for tag in product.tags %}
                      {% if tag contains 'badge_' %}
                        <span class="cct-badge">{{ tag | remove: 'badge_' | replace: '-', ' ' | upcase }}</span>
                      {% endif %}
                    {% endfor %}
                  </div>

                  <div class="cct-card-image">
                    {% if product.featured_image %}
                      {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag }}
                    {% endif %}
                  </div>

                  <div class="cct-card-details">
                    <h3 class="cct-product-title">{{ product.title }}</h3>
                    
                    {% if section.settings.show_vendor and product.vendor != blank %}
                      <p class="cct-product-subtitle">{{ product.vendor | upcase }}</p>
                    {% endif %}

                    <div class="cct-product-price">
                      {% if product.price_varies %}
                        From {{ product.price_min | money }}
                      {% else %}
                        {% if product.compare_at_price > product.price %}
                          <span class="cct-price-sale">{{ product.price | money }}</span>
                          <span class="cct-price-compare"><s>{{ product.compare_at_price | money }}</s></span>
                        {% else %}
                          {{ product.price | money }}
                        {% endif %}
                      {% endif %}
                    </div>

                    <button class="cct-btn-buy" type="button" tabindex="-1">{{ section.settings.button_label }}</button>
                    
                    {% if section.settings.pickup_text != blank %}
                      <div class="cct-pickup-info">
                        <span class="cct-dot"></span> {{ section.settings.pickup_text }}
                      </div>
                    {% endif %}
                  </div>
                </a>
              </div>
              {% endfor %}
          {% else %}
            {% for i in (1..4) %}
              <div class="cct-product-card">
                <div class="cct-card-link-wrapper">
                  <div class="cct-card-image" style="background: rgba(0,0,0,0.05); display:flex; align-items:center; justify-content:center;">
                    <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                  </div>
                  <div class="cct-card-details">
                    <h3 class="cct-product-title">Sample Pastry {{ i }}</h3>
                    <p class="cct-product-subtitle">VANILLA / BUTTER / FLAKY</p>
                    <div class="cct-product-price">$6.00</div>
                    <button class="cct-btn-buy" type="button" tabindex="-1">Buy now</button>
                    <div class="cct-pickup-info"><span class="cct-dot"></span> Available for pickup today</div>
                  </div>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
        
        <div class="cct-nav-controls">
          <button class="cct-nav-arrow prev" aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="cct-nav-dots">
            </div>
          <button class="cct-nav-arrow next" aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>

      </div>
    </div>

    {% if section.settings.collection_2 != blank %}
      <div class="cct-tab-pane" id="tab-2-{{ section.id }}">
        <div class="cct-carousel-wrapper">
          <div class="cct-carousel-track">
            {% for product in section.settings.collection_2.products limit: section.settings.product_limit %}
              
              <div class="cct-product-card">
                <a href="{{ product.url }}" class="cct-card-link-wrapper">
                  
                  <div class="cct-badges">
                    {% if product.compare_at_price > product.price %}
                      {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                      <span class="cct-badge">-{{ discount }}%</span>
                    {% endif %}
                    {% for tag in product.tags %}
                      {% if tag contains 'badge_' %}
                        <span class="cct-badge">{{ tag | remove: 'badge_' | replace: '-', ' ' | upcase }}</span>
                      {% endif %}
                    {% endfor %}
                  </div>

                  <div class="cct-card-image">
                    {% if product.featured_image %}
                      {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag }}
                    {% endif %}
                  </div>

                  <div class="cct-card-details">
                    <h3 class="cct-product-title">{{ product.title }}</h3>
                    
                    {% if section.settings.show_vendor and product.vendor != blank %}
                      <p class="cct-product-subtitle">{{ product.vendor | upcase }}</p>
                    {% endif %}

                    <div class="cct-product-price">
                      {% if product.price_varies %}
                        From {{ product.price_min | money }}
                      {% else %}
                        {% if product.compare_at_price > product.price %}
                          <span class="cct-price-sale">{{ product.price | money }}</span>
                          <span class="cct-price-compare"><s>{{ product.compare_at_price | money }}</s></span>
                        {% else %}
                          {{ product.price | money }}
                        {% endif %}
                      {% endif %}
                    </div>

                    <button class="cct-btn-buy" type="button" tabindex="-1">{{ section.settings.button_label }}</button>
                    
                    {% if section.settings.pickup_text != blank %}
                      <div class="cct-pickup-info">
                        <span class="cct-dot"></span> {{ section.settings.pickup_text }}
                      </div>
                    {% endif %}
                  </div>
                </a>
              </div>
              {% endfor %}
          </div>
          
          <div class="cct-nav-controls">
            <button class="cct-nav-arrow prev" aria-label="Previous">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <div class="cct-nav-dots"></div>
            <button class="cct-nav-arrow next" aria-label="Next">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>

        </div>
      </div>
    {% endif %}

  </div>
</div>

<style>
  /* --- GLOBAL SECTION STYLES --- */
  .custom-collection-tabs-section {
    background-color: var(--bg-color);
    color: var(--text-color);
    padding: 80px 20px;
    overflow: hidden;
  }

  .cct-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .cct-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    margin: 0 0 20px 0;
    color: var(--text-color);
  }

  /* --- TABS --- */
  .cct-tabs-nav {
    display: inline-flex;
    gap: 15px;
  }

  .cct-tab-btn {
    background: transparent;
    border: 1px solid var(--text-color);
    color: var(--text-color);
    padding: 10px 25px;
    border-radius: 30px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cct-tab-btn.active {
    background-color: var(--tab-active-bg);
    color: var(--tab-active-text);
    border-color: var(--tab-active-bg);
  }

  .cct-tab-pane {
    display: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .cct-tab-pane.active {
    display: block;
    opacity: 1;
  }

  /* --- CAROUSEL TRACK --- */
  .cct-carousel-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
  }

  .cct-carousel-track {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE 10+ */
    padding-bottom: 20px;
  }

  .cct-carousel-track::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  /* --- PRODUCT CARD --- */
  .cct-product-card {
    flex: 0 0 calc(33.333% - 20px);
    min-width: 300px;
    background-color: var(--card-bg-color);
    border-radius: 12px;
    scroll-snap-align: start;
    position: relative;
    transition: transform 0.3s ease;
  }

  @media screen and (max-width: 1024px) {
    .cct-product-card { flex: 0 0 calc(50% - 15px); }
  }
  @media screen and (max-width: 768px) {
    .cct-product-card { flex: 0 0 85%; }
  }

  .cct-card-link-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    padding: 30px;
  }

  .cct-badges {
    position: absolute;
    top: 20px;
    right: 20px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: flex-end;
    z-index: 2;
  }

  .cct-badge {
    background-color: var(--badge-bg);
    color: var(--badge-text);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }

  .cct-card-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    margin-bottom: 20px;
  }

  .cct-card-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s ease;
  }

  .cct-product-card:hover .cct-card-image img {
    transform: scale(1.05);
  }

  .cct-card-details {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex-grow: 1;
  }

  .cct-product-title {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 0 0 5px 0;
  }

  .cct-product-subtitle {
    font-size: 0.75rem;
    letter-spacing: 1px;
    opacity: 0.7;
    margin: 0 0 15px 0;
  }

  .cct-product-price {
    font-size: 1.1rem;
    margin-bottom: 20px;
  }

  .cct-price-compare {
    opacity: 0.5;
    margin-left: 5px;
    font-size: 0.9em;
  }

  .cct-btn-buy {
    width: 100%;
    background: transparent;
    border: 1px solid var(--text-color);
    color: var(--text-color);
    padding: 12px;
    border-radius: 30px;
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: auto;
  }

  .cct-product-card:hover .cct-btn-buy {
    background-color: var(--text-color);
    color: var(--bg-color);
  }

  .cct-pickup-info {
    margin-top: 15px;
    font-size: 0.75rem;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0.8;
  }

  .cct-dot {
    width: 8px;
    height: 8px;
    background-color: #2ECC71; /* Green dot */
    border-radius: 50%;
    display: inline-block;
  }

  /* --- BOTTOM CAROUSEL CONTROLS --- */
  .cct-nav-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 20px;
  }

  .cct-nav-arrow {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 0.3s;
  }

  .cct-nav-arrow:hover { opacity: 1; }

  .cct-nav-dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .cct-dot-indicator {
    width: 6px;
    height: 6px;
    background-color: var(--text-color);
    opacity: 0.3;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cct-dot-indicator.active {
    opacity: 1;
    width: 24px;
    border-radius: 4px;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('CollectionTabs-{{ section.id }}');
    if (!section) return;

    // --- TAB LOGIC ---
    const tabBtns = section.querySelectorAll('.cct-tab-btn');
    const tabPanes = section.querySelectorAll('.cct-tab-pane');

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Remove active class from all
        tabBtns.forEach(b => b.classList.remove('active'));
        tabPanes.forEach(p => p.classList.remove('active'));

        // Add active class to clicked
        btn.classList.add('active');
        const targetId = btn.getAttribute('data-target');
        document.getElementById(targetId).classList.add('active');
      });
    });

    // --- CAROUSEL LOGIC ---
    tabPanes.forEach(pane => {
      const track = pane.querySelector('.cct-carousel-track');
      const cards = pane.querySelectorAll('.cct-product-card');
      const dotsContainer = pane.querySelector('.cct-nav-dots');
      const prevBtn = pane.querySelector('.prev');
      const nextBtn = pane.querySelector('.next');

      if (!track || cards.length === 0) return;

      // Generate Dots
      cards.forEach((_, i) => {
        const dot = document.createElement('div');
        dot.classList.add('cct-dot-indicator');
        if (i === 0) dot.classList.add('active');
        
        dot.addEventListener('click', () => {
          track.scrollTo({
            left: cards[i].offsetLeft - track.offsetLeft,
            behavior: 'smooth'
          });
        });
        dotsContainer.appendChild(dot);
      });

      const dots = dotsContainer.querySelectorAll('.cct-dot-indicator');

      // Scroll Event to update dots
      track.addEventListener('scroll', () => {
        let minDistance = Infinity;
        let activeIndex = 0;

        cards.forEach((card, i) => {
          const distance = Math.abs(track.scrollLeft - (card.offsetLeft - track.offsetLeft));
          if (distance < minDistance) {
            minDistance = distance;
            activeIndex = i;
          }
        });

        dots.forEach(d => d.classList.remove('active'));
        if(dots[activeIndex]) dots[activeIndex].classList.add('active');
      });

      // Arrow Clicks
      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          const cardWidth = cards[0].offsetWidth + 30; // + gap
          track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          const cardWidth = cards[0].offsetWidth + 30;
          track.scrollBy({ left: cardWidth, behavior: 'smooth' });
        });
      }
    });
  });
</script>

{% schema %}
{
  "name": "Collection Tabs Carousel",
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Main Background",
      "default": "#c4906a"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Product Card Background",
      "default": "#b5815b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Outline Color",
      "default": "#161616"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "Active Tab Background",
      "default": "#161616"
    },
    {
      "type": "color",
      "id": "tab_active_text",
      "label": "Active Tab Text",
      "default": "#c4906a"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#161616"
    },
    {
      "type": "color",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Heading",
      "default": "Our Pastries"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Primary Collection"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Primary Tab Label",
      "default": "Best Sellers"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Secondary Collection (Optional)",
      "info": "Leave blank to hide the tabs and only show one collection."
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Secondary Tab Label",
      "default": "Seasonal Bakes"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Max Products per Collection",
      "default": 6
    },
    {
      "type": "header",
      "content": "Card Details"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show Vendor/Subtitle",
      "info": "Displays the product vendor under the title. Useful for flavor notes.",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Order Now"
    },
    {
      "type": "text",
      "id": "pickup_text",
      "label": "Pickup Text",
      "default": "Available for pickup in-store",
      "info": "Leave blank to hide the green dot and text."
    }
  ],
  "presets": [
    {
      "name": "Collection Tabs Carousel"
    }
  ]
}
{% endschema %}