<div id="CustomDualCards-{{ section.id }}" class="custom-dual-cards" style="
  background: {{ section.settings.section_bg }};
  --text-color: {{ section.settings.text_color }};
  --accent-color: {{ section.settings.accent_color }};
  --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  --card-height-desktop: {{ section.settings.card_height_desktop }}px;
  --card-height-mobile: {{ section.settings.card_height_mobile }}px;
  --corner-radius: {{ section.settings.corner_radius }}px;
  --padding-top-desktop: {{ section.settings.padding_top }}px;
  --padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
">
  
  <div class="cdc-container">
    {% for block in section.blocks limit: 2 %}
      
      <a href="{{ block.settings.link }}" class="cdc-card" {{ block.shopify_attributes }}>
        
        <div class="cdc-bg-wrapper">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'cdc-img' }}
          {% else %}
            {{ 'collection-2' | placeholder_svg_tag: 'cdc-placeholder' }}
          {% endif %}
          <div class="cdc-overlay"></div>
        </div>

        <div class="cdc-content">
          {% if block.settings.subheading != blank %}
            <span class="cdc-subheading">{{ block.settings.subheading }}</span>
          {% endif %}
          
          {% if block.settings.heading != blank %}
            <h2 class="cdc-heading">{{ block.settings.heading }}</h2>
          {% endif %}
          
          {% if block.settings.button_label != blank %}
            <span class="cdc-button">{{ block.settings.button_label }}</span>
          {% endif %}
        </div>
        
      </a>

    {% endfor %}
  </div>

</div>

<style>
  #CustomDualCards-{{ section.id }} {
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .cdc-container {
    width: 90%;
    max-width: 1200px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }

  .cdc-card {
    position: relative;
    border-radius: var(--corner-radius);
    overflow: hidden;
    height: var(--card-height-desktop);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--text-color);
    transition: transform 0.3s ease;
  }

  .cdc-card:hover {
    transform: translateY(-5px);
  }

  /* --- BACKGROUND & OVERLAY --- */
  .cdc-bg-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .cdc-img, .cdc-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .cdc-placeholder {
    background-color: #333;
  }

  .cdc-card:hover .cdc-img, 
  .cdc-card:hover .cdc-placeholder {
    transform: scale(1.05);
  }

  .cdc-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, var(--overlay-opacity));
    transition: background-color 0.3s ease;
  }

  .cdc-card:hover .cdc-overlay {
    background-color: rgba(0, 0, 0, calc(var(--overlay-opacity) + 0.15));
  }

  /* --- FOREGROUND CONTENT --- */
  .cdc-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 30px;
    width: 100%;
  }

  .cdc-subheading {
    font-size: 0.85rem;
    letter-spacing: 1px;
    margin-bottom: 12px;
    opacity: 0.9;
  }

  .cdc-heading {
    color: var(--accent-color); /* The bright orange/tan color from screenshot */
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    margin: 0 0 25px 0;
    line-height: 1.2;
  }

  .cdc-button {
    display: inline-block;
    padding: 10px 30px;
    border: 1px solid var(--accent-color);
    color: var(--accent-color);
    border-radius: 40px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .cdc-card:hover .cdc-button {
    background-color: var(--accent-color);
    color: #111; /* Dark text on hover */
  }

  /* --- MOBILE OVERRIDES --- */
  @media screen and (max-width: 768px) {
    #CustomDualCards-{{ section.id }} {
      padding-top: var(--padding-top-mobile);
      padding-bottom: var(--padding-bottom-mobile);
    }
    .cdc-container {
      grid-template-columns: 1fr; /* Stack vertically on phones */
      gap: 20px;
    }
    .cdc-card {
      height: var(--card-height-mobile);
    }
  }
</style>

{% schema %}
{
  "name": "Dual Promotional Cards",
  "max_blocks": 2,
  "settings": [
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color_background",
      "id": "section_bg",
      "label": "Section Background",
      "default": "linear-gradient(180deg, #1c1815 0%, #302016 100%)",
      "info": "You can use a solid color or a gradient."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Subheading Text Color",
      "default": "#f4e9dd"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Heading & Button Color",
      "default": "#c4906a"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Dark Image Overlay",
      "default": 40,
      "info": "Helps make text readable over images."
    },
    {
      "type": "header",
      "content": "Card Layout"
    },
    {
      "type": "range",
      "id": "card_height_desktop",
      "min": 300,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Card Height (Desktop)",
      "default": 500
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "min": 250,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Card Height (Mobile)",
      "default": 400
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card Corner Radius",
      "default": 16
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Promotional Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "About Our Bakery"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Main Heading",
          "default": "Our Story"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Text",
          "default": "Read"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link",
          "info": "Makes the entire card clickable."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dual Promotional Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "subheading": "About The Bakery",
            "heading": "Our Story",
            "button_label": "Read"
          }
        },
        {
          "type": "card",
          "settings": {
            "subheading": "Place to start",
            "heading": "Our Menu",
            "button_label": "Explore"
          }
        }
      ]
    }
  ]
}
{% endschema %}