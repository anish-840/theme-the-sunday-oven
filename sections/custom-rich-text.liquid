<div id="CustomRichText-{{ section.id }}" class="custom-rich-text-wrapper" style="
  --bg-color: {{ section.settings.bg_color }};
  --text-color: {{ section.settings.text_color }};
  --padding-top-desktop: {{ section.settings.padding_top }}px;
  --padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  --max-width: {{ section.settings.max_width }}px;
  --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
  --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
  --text-alignment: {{ section.settings.text_alignment }};
">
  <div class="crt-container">
    
    {% if section.settings.subheading != blank %}
      <div class="crt-subheading">
        {{ section.settings.subheading }}
      </div>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="crt-heading">
        {{ section.settings.heading | newline_to_br }}
      </h2>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="crt-button">
        {{ section.settings.button_label }}
      </a>
    {% endif %}

  </div>
</div>

<style>
  #CustomRichText-{{ section.id }} {
    background-color: var(--bg-color);
    color: var(--text-color);
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
    width: 100%;
    display: flex;
    justify-content: center;
  }

  #CustomRichText-{{ section.id }} .crt-container {
    width: 90%;
    max-width: var(--max-width);
    text-align: var(--text-alignment);
    display: flex;
    flex-direction: column;
    /* Aligns the flex items based on the text-alignment setting */
    align-items: {% if section.settings.text_alignment == 'left' %}flex-start{% elsif section.settings.text_alignment == 'right' %}flex-end{% else %}center{% endif %};
  }

  /* Subheading - targets the p tags generated by the rich text editor */
  #CustomRichText-{{ section.id }} .crt-subheading,
  #CustomRichText-{{ section.id }} .crt-subheading p {
    font-size: 1.1rem;
    margin: 0 0 20px 0;
    opacity: 0.9;
  }

  #CustomRichText-{{ section.id }} .crt-subheading strong, 
  #CustomRichText-{{ section.id }} .crt-subheading b {
    font-weight: 700;
  }

  /* Main Heading */
  #CustomRichText-{{ section.id }} .crt-heading {
    color: var(--text-color);
    font-size: var(--heading-size-desktop);
    line-height: 1.3;
    font-weight: 500;
    margin: 0 0 40px 0;
    letter-spacing: 0.5px;
  }

  /* Hollow Pill Button */
  #CustomRichText-{{ section.id }} .crt-button {
    display: inline-block;
    padding: 14px 40px;
    text-decoration: none;
    background-color: transparent;
    color: var(--text-color);
    border: 1px solid var(--text-color);
    border-radius: 40px; 
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  #CustomRichText-{{ section.id }} .crt-button:hover {
    background-color: var(--text-color);
    color: var(--bg-color); /* Inverts on hover automatically */
    transform: translateY(-2px);
  }

  /* Mobile Adjustments */
  @media screen and (max-width: 768px) {
    #CustomRichText-{{ section.id }} {
      padding-top: var(--padding-top-mobile);
      padding-bottom: var(--padding-bottom-mobile);
    }
    
    #CustomRichText-{{ section.id }} .crt-heading {
      font-size: var(--heading-size-mobile);
      margin: 0 0 30px 0;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Rich Text",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#161616"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Button Color",
      "default": "#c4906a"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>We are <strong>Caffeine</strong></p>",
      "info": "Use the bold tool to highlight specific words."
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "At our core, we're coffee artisans, carefully roasting each batch to unlock the unique flavors within every bean, delivering a remarkable cup with every roast ;)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Show more"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Sizing & Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "label": "Maximum Text Width",
      "default": 900
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Desktop Heading Size",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Mobile Heading Size",
      "default": 32
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Custom Rich Text"
    }
  ]
}
{% endschema %}