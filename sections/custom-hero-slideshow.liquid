{%- liquid
  # Calculate the aspect ratio for 'auto' height based on the first slide
  assign aspect_ratio_desktop = '16/9'
  assign aspect_ratio_mobile = '1/1'
  
  if section.blocks.size > 0
    assign first_image = section.blocks.first.settings.image
    assign first_image_mobile = section.blocks.first.settings.image_mobile
    
    if first_image != blank
      assign aspect_ratio_desktop = first_image.aspect_ratio
      assign aspect_ratio_mobile = first_image.aspect_ratio
    endif
    
    if first_image_mobile != blank
      assign aspect_ratio_mobile = first_image_mobile.aspect_ratio
    endif
  endif
-%}

<div class="custom-slideshow-section height-{{ section.settings.section_height }}" id="Slideshow-{{ section.id }}" 
     style="
       --nav-bg: {{ section.settings.nav_bg_color }}; 
       --nav-text: {{ section.settings.nav_text_color }};
       {% if section.settings.section_height == 'custom' %}
         --section-height: {{ section.settings.custom_height_desktop }}px;
         --section-height-mobile: {{ section.settings.custom_height_mobile }}px;
       {% elsif section.settings.section_height == 'small' %}
         --section-height: 500px;
         --section-height-mobile: 400px;
       {% elsif section.settings.section_height == 'medium' %}
         --section-height: 700px;
         --section-height-mobile: 500px;
       {% elsif section.settings.section_height == 'large' %}
         --section-height: 900px;
         --section-height-mobile: 700px;
       {% elsif section.settings.section_height == 'fullscreen' %}
         --section-height: 100vh;
         --section-height-mobile: 100vh;
       {% elsif section.settings.section_height == 'auto' %}
         --aspect-ratio-desktop: {{ aspect_ratio_desktop }};
         --aspect-ratio-mobile: {{ aspect_ratio_mobile }};
       {% endif %}
     "
     data-autoplay="{{ section.settings.autoplay }}"
     data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">

  <div class="slideshow-track">
    {% for block in section.blocks %}
      <div class="slide {% if forloop.first %}active{% endif %}" 
           data-index="{{ forloop.index0 }}" 
           style="background-color: {{ block.settings.bg_color }};" 
           {{ block.shopify_attributes }}>
        
        <div class="slide-background">
          {% if block.settings.image != blank %}
            <picture>
              {% if block.settings.image_mobile != blank %}
                <source media="(max-width: 768px)" srcset="{{ block.settings.image_mobile | image_url: width: 800 }}">
              {% endif %}
              {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', class: 'hero-bg-img' }}
            </picture>
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg hero-bg-img' }}
          {% endif %}
          <div class="bg-overlay" style="background: rgba(0,0,0, {{ block.settings.overlay_opacity | divided_by: 100.0 }});"></div>
        </div>

        <div class="slide-inner text-position-{{ block.settings.text_position }}">
          <div class="slide-text-box" style="
              text-align: {% if block.settings.text_position == 'left' %}left{% elsif block.settings.text_position == 'right' %}right{% else %}center{% endif %};
              align-items: {% if block.settings.text_position == 'left' %}flex-start{% elsif block.settings.text_position == 'right' %}flex-end{% else %}center{% endif %};
            ">
            
            {% if block.settings.subheading != blank %}
              <span class="slide-subheading" style="color: {{ block.settings.subheading_color }}; font-size: {{ block.settings.subheading_size }}px;">
                {{ block.settings.subheading }}
              </span>
            {% endif %}
            
            {% if block.settings.title != blank %}
              <h2 class="slide-heading" style="color: {{ block.settings.heading_color }}; font-size: {{ block.settings.heading_size }}px;">
                {{ block.settings.title | newline_to_br }}
              </h2>
            {% endif %}
            
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="slide-button" 
                 style="
                   background-color: {{ block.settings.btn_bg_color }}; 
                   color: {{ block.settings.btn_text_color }};
                   border-radius: {{ section.settings.button_radius }}px;
                 ">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>
        </div>

      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="slideshow-nav-bar">
      <div class="nav-container">
        {% if section.settings.show_arrows %}
          <button class="nav-arrow prev" aria-label="Previous Slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
        {% endif %}
        
        {% if section.settings.show_dots %}
          <div class="nav-dots">
            {% for block in section.blocks %}
              <button class="nav-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.show_arrows %}
          <button class="nav-arrow next" aria-label="Next Slide">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>

<style>
  .custom-slideshow-section {
    position: relative;
    width: 100%;
    height: var(--section-height);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* Support for Auto (Aspect Ratio) Height */
  .custom-slideshow-section.height-auto {
    height: auto;
    aspect-ratio: var(--aspect-ratio-desktop);
  }

  .slideshow-track {
    position: relative;
    width: 100%;
    flex-grow: 1; 
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
  }

  .slide.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  /* --- BACKGROUND --- */
  .slide-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-bg-img, .placeholder-svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none; 
  }

  /* --- TEXT LAYERS --- */
  .slide-inner {
    position: relative;
    z-index: 2; 
    display: flex;
    align-items: center; 
    height: 100%;
    width: 90%;
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding-bottom: {{ section.settings.nav_height }}px; /* Keeps text from hitting the hover nav */
  }

  .slide-inner.text-position-left { justify-content: flex-start; }
  .slide-inner.text-position-center { justify-content: center; }
  .slide-inner.text-position-right { justify-content: flex-end; }

  .slide-text-box {
    display: flex;
    flex-direction: column;
    max-width: 600px; 
    padding: 2rem 0;
  }

  .slide-subheading {
    margin-bottom: 15px;
    font-weight: 500;
  }

  .slide-heading {
    line-height: 1.1;
    margin: 0 0 30px 0;
    font-weight: 700;
  }

  .slide-button {
    display: inline-block;
    padding: 15px 35px;
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .slide-button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  /* --- NAVIGATION BAR --- */
  .slideshow-nav-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: {{ section.settings.nav_height }}px;
    background-color: var(--nav-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .nav-container {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .nav-arrow {
    background: none;
    border: none;
    color: var(--nav-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .nav-arrow:hover { opacity: 1; }

  .nav-dots {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .nav-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--nav-text);
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .nav-dot.active {
    opacity: 1;
    width: 24px;
    border-radius: 10px;
  }

  /* --- MOBILE OVERRIDES --- */
  @media screen and (max-width: 768px) {
    .custom-slideshow-section {
      height: var(--section-height-mobile);
    }
    
    .custom-slideshow-section.height-auto {
      aspect-ratio: var(--aspect-ratio-mobile);
    }

    .slide-inner {
      justify-content: center !important; 
      align-items: center !important;
    }

    .slide-text-box {
      text-align: center !important;
      align-items: center !important;
      padding: 20px;
      background: rgba(255,255,255,0.8); 
      border-radius: 10px;
    }

    .slide-heading {
      font-size: clamp(2.5rem, 8vw, 3.5rem) !important;
    }
  }
</style>

<script>
  class CustomSlideshow extends HTMLElement {
    constructor() {
      super();
      this.section = this;
      this.slides = this.querySelectorAll('.slide');
      this.dots = this.querySelectorAll('.nav-dot');
      this.prevBtn = this.querySelector('.prev');
      this.nextBtn = this.querySelector('.next');
      this.currentIndex = 0;
      this.autoplay = this.dataset.autoplay === 'true';
      this.speed = parseInt(this.dataset.speed);
      this.interval = null;

      if (this.slides.length <= 1) return;

      this.bindEvents();
      if (this.autoplay) this.startAutoplay();
    }

    bindEvents() {
      if (this.prevBtn) this.prevBtn.addEventListener('click', () => this.navigate(-1));
      if (this.nextBtn) this.nextBtn.addEventListener('click', () => this.navigate(1));
      
      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', () => this.goToSlide(index));
      });

      this.section.addEventListener('mouseenter', () => this.stopAutoplay());
      this.section.addEventListener('mouseleave', () => {
        if (this.autoplay) this.startAutoplay();
      });
    }

    navigate(direction) {
      let index = this.currentIndex + direction;
      if (index < 0) index = this.slides.length - 1;
      if (index >= this.slides.length) index = 0;
      this.goToSlide(index);
    }

    goToSlide(index) {
      this.slides[this.currentIndex].classList.remove('active');
      if (this.dots.length) this.dots[this.currentIndex].classList.remove('active');
      
      this.currentIndex = index;
      
      this.slides[this.currentIndex].classList.add('active');
      if (this.dots.length) this.dots[this.currentIndex].classList.add('active');
    }

    startAutoplay() {
      this.stopAutoplay();
      this.interval = setInterval(() => this.navigate(1), this.speed);
    }

    stopAutoplay() {
      if (this.interval) clearInterval(this.interval);
    }
  }

  customElements.define('custom-slideshow', CustomSlideshow);

  document.addEventListener('shopify:block:select', function(event) {
    const slide = event.target;
    if (!slide.classList.contains('slide')) return;
    const index = parseInt(slide.dataset.index);
    const slideshow = slide.closest('custom-slideshow');
    if (slideshow) {
      slideshow.stopAutoplay();
      slideshow.goToSlide(index);
    }
  });
</script>

<custom-slideshow style="display: block; width: 100%; height: 100%;"></custom-slideshow>

{% schema %}
{
  "name": "Full Background Slideshow",
  "settings": [
    {
      "type": "header",
      "content": "Height Controls"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Slideshow Height",
      "options": [
        { "value": "auto", "label": "Adapt to first image" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "fullscreen", "label": "Fullscreen" },
        { "value": "custom", "label": "Custom (Use sliders below)" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "custom_height_desktop",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "label": "Custom Height (Desktop)",
      "info": "Only works if 'Custom' is selected above.",
      "default": 750
    },
    {
      "type": "range",
      "id": "custom_height_mobile",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Custom Height (Mobile)",
      "info": "Only works if 'Custom' is selected above.",
      "default": 650
    },
    {
      "type": "header",
      "content": "Content Width"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Text Width",
      "default": 1200
    },
    {
      "type": "header",
      "content": "Functionality"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": false
