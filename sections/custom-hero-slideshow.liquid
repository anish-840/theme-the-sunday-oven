<div class="custom-slideshow-section" id="Slideshow-{{ section.id }}" 
     style="
       --nav-bg: {{ section.settings.nav_bg_color }}; 
       --nav-text: {{ section.settings.nav_text_color }};
       --section-height: {{ section.settings.desktop_height }};
       --section-height-mobile: {{ section.settings.mobile_height }};
     "
     data-autoplay="{{ section.settings.autoplay }}"
     data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">

  <div class="slideshow-track">
    {% for block in section.blocks %}
      <div class="slide {% if forloop.first %}active{% endif %}" 
           data-index="{{ forloop.index0 }}" 
           style="background-color: {{ block.settings.bg_color }};" 
           {{ block.shopify_attributes }}>
        
        <div class="slide-inner layout-{{ block.settings.layout }}">
          
          <div class="slide-text-content" style="align-items: {{ block.settings.text_alignment }}; text-align: {% if block.settings.text_alignment == 'flex-start' %}left{% elsif block.settings.text_alignment == 'flex-end' %}right{% else %}center{% endif %};">
            {% if block.settings.subheading != blank %}
              <span class="slide-subheading" style="color: {{ block.settings.subheading_color }}; font-size: {{ block.settings.subheading_size }}px;">
                {{ block.settings.subheading }}
              </span>
            {% endif %}
            
            {% if block.settings.title != blank %}
              <h2 class="slide-heading" style="color: {{ block.settings.heading_color }}; font-size: {{ block.settings.heading_size }}px;">
                {{ block.settings.title | newline_to_br }}
              </h2>
            {% endif %}
            
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link }}" class="slide-button" 
                 style="
                   background-color: {{ block.settings.btn_bg_color }}; 
                   color: {{ block.settings.btn_text_color }};
                   border-radius: {{ section.settings.button_radius }}px;
                 ">
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>

          <div class="slide-image-content">
            {% if block.settings.image != blank %}
              <picture>
                {% if block.settings.image_mobile != blank %}
                  <source media="(max-width: 768px)" srcset="{{ block.settings.image_mobile | image_url: width: 600 }}">
                {% endif %}
                {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', class: 'hero-img' }}
              </picture>
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg hero-img' }}
            {% endif %}
          </div>

        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.blocks.size > 1 %}
    <div class="slideshow-nav-bar">
      <div class="nav-container">
        {% if section.settings.show_arrows %}
          <button class="nav-arrow prev" aria-label="Previous Slide">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
        {% endif %}
        
        {% if section.settings.show_dots %}
          <div class="nav-dots">
            {% for block in section.blocks %}
              <button class="nav-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.show_arrows %}
          <button class="nav-arrow next" aria-label="Next Slide">
             <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        {% endif %}
      </div>
    </div>
  {% endif %}
</div>

<style>
  .custom-slideshow-section {
    position: relative;
    width: 100%;
    height: var(--section-height);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .slideshow-track {
    position: relative;
    width: 100%;
    flex-grow: 1; /* Takes up all space minus the nav bar */
  }

  .slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease-in-out, visibility 0.6s ease-in-out;
  }

  .slide.active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .slide-inner {
    display: flex;
    width: 90%;
    max-width: {{ section.settings.container_width }}px;
    height: 100%;
    margin: 0 auto;
    align-items: center;
    gap: 40px;
  }

  /* Layout Reversals */
  .slide-inner.layout-image_right { flex-direction: row; }
  .slide-inner.layout-image_left { flex-direction: row-reverse; }

  .slide-text-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 0;
  }

  .slide-subheading {
    margin-bottom: 15px;
    font-weight: 500;
  }

  .slide-heading {
    line-height: 1.1;
    margin: 0 0 30px 0;
    font-weight: 700;
  }

  .slide-button {
    display: inline-block;
    padding: 15px 35px;
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .slide-button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  .slide-image-content {
    flex: 1.2;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-img {
    max-width: 100%;
    max-height: 90%;
    object-fit: contain;
  }

  .placeholder-svg {
    width: 100%;
    height: 60%;
    background-color: rgba(0,0,0,0.1);
  }

  /* Bottom Navigation Bar */
  .slideshow-nav-bar {
    width: 100%;
    height: {{ section.settings.nav_height }}px;
    background-color: var(--nav-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .nav-container {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .nav-arrow {
    background: none;
    border: none;
    color: var(--nav-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .nav-arrow:hover { opacity: 1; }

  .nav-dots {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .nav-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: var(--nav-text);
    opacity: 0.3;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }

  .nav-dot.active {
    opacity: 1;
    width: 24px;
    border-radius: 10px;
  }

  /* Mobile Overrides */
  @media screen and (max-width: 768px) {
    .custom-slideshow-section {
      height: var(--section-height-mobile);
    }
    .slide-inner.layout-image_right,
    .slide-inner.layout-image_left {
      flex-direction: column-reverse;
      text-align: center;
      gap: 20px;
    }
    .slide-text-content {
      align-items: center !important;
      text-align: center !important;
      padding-top: 0;
    }
    .slide-heading {
      font-size: clamp(2rem, 8vw, 3rem) !important;
    }
    .slide-image-content {
      flex: 1;
      width: 100%;
      padding-top: 20px;
    }
  }
</style>

<script>
  class CustomSlideshow extends HTMLElement {
    constructor() {
      super();
      this.section = this;
      this.slides = this.querySelectorAll('.slide');
      this.dots = this.querySelectorAll('.nav-dot');
      this.prevBtn = this.querySelector('.prev');
      this.nextBtn = this.querySelector('.next');
      this.currentIndex = 0;
      this.autoplay = this.dataset.autoplay === 'true';
      this.speed = parseInt(this.dataset.speed);
      this.interval = null;

      if (this.slides.length <= 1) return;

      this.bindEvents();
      if (this.autoplay) this.startAutoplay();
    }

    bindEvents() {
      if (this.prevBtn) this.prevBtn.addEventListener('click', () => this.navigate(-1));
      if (this.nextBtn) this.nextBtn.addEventListener('click', () => this.navigate(1));
      
      this.dots.forEach((dot, index) => {
        dot.addEventListener('click', () => this.goToSlide(index));
      });

      // Pause on hover
      this.section.addEventListener('mouseenter', () => this.stopAutoplay());
      this.section.addEventListener('mouseleave', () => {
        if (this.autoplay) this.startAutoplay();
      });
    }

    navigate(direction) {
      let index = this.currentIndex + direction;
      if (index < 0) index = this.slides.length - 1;
      if (index >= this.slides.length) index = 0;
      this.goToSlide(index);
    }

    goToSlide(index) {
      this.slides[this.currentIndex].classList.remove('active');
      if (this.dots.length) this.dots[this.currentIndex].classList.remove('active');
      
      this.currentIndex = index;
      
      this.slides[this.currentIndex].classList.add('active');
      if (this.dots.length) this.dots[this.currentIndex].classList.add('active');
    }

    startAutoplay() {
      this.stopAutoplay();
      this.interval = setInterval(() => this.navigate(1), this.speed);
    }

    stopAutoplay() {
      if (this.interval) clearInterval(this.interval);
    }
  }

  customElements.define('custom-slideshow', CustomSlideshow);

  // Shopify Theme Editor Support (switches to slide when block is clicked)
  document.addEventListener('shopify:block:select', function(event) {
    const slide = event.target;
    if (!slide.classList.contains('slide')) return;
    const index = parseInt(slide.dataset.index);
    const slideshow = slide.closest('custom-slideshow');
    if (slideshow) {
      slideshow.stopAutoplay();
      slideshow.goToSlide(index);
    }
  });
</script>

<custom-slideshow style="display: block; width: 100%; height: 100%;">
  </custom-slideshow>
{% schema %}
{
  "name": "Hero Slideshow",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "desktop_height",
