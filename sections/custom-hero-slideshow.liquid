      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Navigation Bar"
    },
    {
      "type": "range",
      "id": "nav_height",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Bar Height",
      "default": 70
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
