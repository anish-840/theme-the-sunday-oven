<div id="CustomFeatureIcons-{{ section.id }}" class="custom-feature-icons" style="
  --bg-color: {{ section.settings.bg_color }};
  --text-color: {{ section.settings.text_color }};
  --icon-size: {{ section.settings.icon_size }}px;
  --columns-desktop: {{ section.settings.columns_desktop }};
  --columns-mobile: {{ section.settings.columns_mobile }};
  --padding-top-desktop: {{ section.settings.padding_top }}px;
  --padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
  --padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
  --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
">
  
  <div class="cfi-container">
    {% for block in section.blocks %}
      <div class="cfi-block" {{ block.shopify_attributes }}>
        
        <div class="cfi-icon-wrapper">
          {% if block.settings.custom_svg != blank %}
            <div class="cfi-svg">
              {{ block.settings.custom_svg }}
            </div>
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'cfi-img' }}
          {% else %}
            <div class="cfi-svg">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v8m-4-4h8"/></svg>
            </div>
          {% endif %}
        </div>

        {% if block.settings.heading != blank %}
          <h3 class="cfi-heading">{{ block.settings.heading }}</h3>
        {% endif %}
        
        {% if block.settings.text != blank %}
          <div class="cfi-text">{{ block.settings.text }}</div>
        {% endif %}
        
      </div>
    {% endfor %}
  </div>

</div>

<style>
  #CustomFeatureIcons-{{ section.id }} {
    background-color: var(--bg-color);
    color: var(--text-color);
    padding-top: var(--padding-top-desktop);
    padding-bottom: var(--padding-bottom-desktop);
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .cfi-container {
    width: 90%;
    max-width: 1400px;
    display: grid;
    grid-template-columns: repeat(var(--columns-desktop), 1fr);
    gap: 40px;
    align-items: start;
  }

  .cfi-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cfi-icon-wrapper {
    width: var(--icon-size);
    height: var(--icon-size);
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cfi-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .cfi-svg svg {
    width: 100%;
    height: 100%;
    color: var(--text-color);
    fill: transparent;
  }

  .cfi-heading {
    color: var(--text-color);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 12px 0;
    line-height: 1.3;
  }

  .cfi-text {
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.85;
    margin: 0;
  }

  .cfi-text p {
    margin: 0;
  }

  /* --- MOBILE RESPONSIVENESS --- */
  @media screen and (max-width: 992px) {
    .cfi-container {
      grid-template-columns: repeat(2, 1fr); /* 2 columns on tablets */
    }
  }

  @media screen and (max-width: 768px) {
    #CustomFeatureIcons-{{ section.id }} {
      padding-top: var(--padding-top-mobile);
      padding-bottom: var(--padding-bottom-mobile);
    }
    .cfi-container {
      grid-template-columns: repeat(var(--columns-mobile), 1fr); /* 1 or 2 cols based on setting */
      gap: 30px;
    }
    .cfi-icon-wrapper {
      margin-bottom: 16px;
    }
    .cfi-heading {
      font-size: 1.15rem;
    }
  }
</style>

{% schema %}
{
  "name": "Feature Icons",
  "max_blocks": 6,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#c48b64"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Icon Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "icon_size",
      "min": 30,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Icon/Image Size",
      "default": 60
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns on Desktop",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on Mobile",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Icon",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image Icon",
          "info": "PNG with transparent background works best."
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Code (Optional)",
          "info": "Paste raw SVG code here for the crispest icons. This overrides the image picker."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>A short description of this feature or promise.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Icons",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "heading": "Baked Fresh Daily",
            "text": "<p>Every loaf and pastry is crafted from scratch early every morning.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Artisanal Ingredients",
            "text": "<p>We source only the finest local flours, organic butter, and seasonal fruits.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Local Delivery",
            "text": "<p>Enjoy our warm baked goods delivered right to your doorstep.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "heading": "Order for Pickup",
            "text": "<p>Skip the line! Order your daily bread online and grab it to go.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}